**Load all messages history conservations
def load_history():
    conn = sqlite3.connect("chat_history.db")
    cursor = conn.cursor()
    cursor.execute('SELECT sender, message, timestamp FROM messages ORDER BY id')
    rows = cursor.fetchall()
    conn.close()
    return rows
